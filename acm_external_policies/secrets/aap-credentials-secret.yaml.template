# DO NOT COMMIT THIS FILE TO GIT — it contains sensitive credentials.
# Apply manually:  oc apply -f aap-credentials-secret.yaml
# Or use SealedSecrets / External Secrets Operator for GitOps workflows.
#
# FIX #11 — This Secret now also holds Azure and F5 credentials that were
# previously passed as plain extra_vars in PolicyAutomation. AAP reads these
# from this Secret via the credential type mapping, keeping them out of
# PolicyAutomation objects stored in etcd.
apiVersion: v1
kind: Secret
metadata:
  name: aap-credentials
  namespace: acm-policies
type: Opaque
stringData:
  # ──── AAP Controller ────
  token: "<REPLACE: your-aap-controller-api-token>"
  host: "https://aap-controller.mydomain.no"
  # ──── Azure Entra (used by Ansible playbooks) ────
  azure_tenant_id: "<REPLACE: your-azure-tenant-id>"
  azure_app_id: "<REPLACE: your-app-registration-client-id>"
